<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_dark_card_bg">

    <!-- Teal accent line at top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#2E7D6F" />

    <!-- Main content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Daily tip with quote icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌟 "
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tip_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="每坚持一天，你的肺功能都在恢复。继续保持！"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.3"
                android:maxLines="3"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Horizontal divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#333333" />

        <!-- Streak badge row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 "
                android:textSize="14sp" />

            <TextView
                android:id="@+id/streak_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 天连续"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFB74D" />
        </LinearLayout>

        <!-- AI insight (hidden by default) -->
        <TextView
            android:id="@+id/insight_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textSize="12sp"
            android:textColor="#90A4AE"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
