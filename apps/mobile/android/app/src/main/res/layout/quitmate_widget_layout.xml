<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_dark_gradient_bg">

    <!-- Day counter row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="baseline"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widget_days"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="第 -- 天"
            android:textSize="40sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="天"
            android:textSize="14sp"
            android:textColor="#90A4AE" />
    </LinearLayout>

    <!-- Recovery progress bar -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress_teal" />

    <TextView
        android:id="@+id/widget_recovery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="身体恢复 --%"
        android:textSize="12sp"
        android:textColor="#78909C" />

    <!-- Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_money"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="¥ -- 已省"
            android:textSize="14sp"
            android:textColor="#B0BEC5" />

        <TextView
            android:id="@+id/widget_life"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❤️ +-- 天生命"
            android:textSize="14sp"
            android:textColor="#B0BEC5" />
    </LinearLayout>

    <!-- Compact SOS button -->
    <Button
        android:id="@+id/widget_sos"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_sos_bg"
        android:text="SOS 渴望来了"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textAllCaps="false"
        android:minHeight="0dp"
        android:minWidth="0dp" />

</LinearLayout>
