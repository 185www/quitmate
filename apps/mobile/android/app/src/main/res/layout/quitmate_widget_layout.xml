<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QuitMate"
        android:textSize="14sp"
        android:textColor="#82B1FF"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_days"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="第 -- 天"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_money"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="💰 已省 ¥--"
        android:textSize="14sp"
        android:textColor="#B0BEC5" />

    <TextView
        android:id="@+id/widget_life"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="❤️ +-- 天生命"
        android:textSize="14sp"
        android:textColor="#B0BEC5" />

    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#82B1FF"
        android:progressBackgroundTint="#37474F" />

    <TextView
        android:id="@+id/widget_recovery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="身体恢复 --%"
        android:textSize="11sp"
        android:textColor="#78909C" />

    <Button
        android:id="@+id/widget_sos"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#4A90D9"
        android:text="🧘 SOS 呼吸法"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textAllCaps="false" />

</LinearLayout>
